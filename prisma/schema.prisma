generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  /// bcrypt hash of the login password — used by next-auth for authentication only, never for encryption
  passwordHash String
  resetTokenHash    String?
  resetTokenExpiry  DateTime?
  emailVerified     Boolean   @default(false)
  verificationToken String?   @unique
  /// base32-encoded TOTP secret; null when 2FA is not set up
  totpSecret        String?
  totpEnabled       Boolean   @default(false)
  /// SHA-256 hashes of single-use backup codes; consumed on use
  totpBackupCodes   String[]  @default([])
  createdAt         DateTime     @default(now())
  vaults            Vault[]
  tags              Tag[]
  loginAudits       LoginAudit[]
  userSessions      UserSession[]
  customEntryTypes  CustomEntryType[]
  shareLinks        ShareLink[]
}

model Vault {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// display name chosen by the user (e.g. "Personal", "Work")
  name      String
  /// base64-encoded PBKDF2 salt; combined with this vault's password in-browser to derive the AES-256-GCM key
  salt      String
  /// base64-encoded PBKDF2 salt for the decoy password; null when no decoy is configured
  decoySalt String?
  entries   VaultEntry[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, name])
}

model VaultEntry {
  id            String         @id @default(cuid())
  vaultId       String
  vault         Vault          @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  /// base64-encoded AES-256-GCM ciphertext of the vault entry JSON; server never decrypts this
  encryptedBlob String
  /// base64-encoded AES-GCM initialization vector; unique per entry, safe to store in plaintext
  iv            String
  pinned        Boolean        @default(false)
  /// "login" | "note" | "card" | "identity" — mirrors the type field inside the encrypted blob
  entryType     String         @default("login")
  /// true when this entry belongs to the decoy view (visible only when vault unlocked with decoy password)
  isDecoy       Boolean        @default(false)
  /// set when the entry is soft-deleted; null means active
  deletedAt     DateTime?
  tags          Tag[]
  history       EntryHistory[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([vaultId, isDecoy, deletedAt])
}

/// Snapshots of a VaultEntry taken before each update; at most 10 kept per entry
model EntryHistory {
  id            String     @id @default(cuid())
  entryId       String
  entry         VaultEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  encryptedBlob String
  iv            String
  savedAt       DateTime   @default(now())

  @@index([entryId])
}

model Tag {
  id           String       @id @default(cuid())
  userId       String
  /// scoped to the owning user so tags are shared across all their vaults
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  vaultEntries VaultEntry[]
  createdAt    DateTime     @default(now())

  @@unique([userId, name])
}

/// One row per successful sign-in; deleted on "sign out everywhere"; cascades on user delete
model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String
  userAgent String
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

/// User-defined entry type; fields stores a CustomFieldDef[] JSON array
model CustomEntryType {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  fields    Json
  createdAt DateTime @default(now())

  @@unique([userId, name])
  @@index([userId])
}

/// Login events recorded on every credential attempt where a userId is known; cascades on user delete
model LoginAudit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String
  success   Boolean
  /// "password" | "totp" | "backup_code"
  method    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

/// A time-limited, publicly-accessible link for sharing a single vault entry.
/// The entry is re-encrypted client-side with a key derived from the raw token;
/// the server only stores the SHA-256 hash of the token and the re-encrypted blob.
model ShareLink {
  id            String   @id @default(cuid())
  /// SHA-256 hex hash of the raw URL token — never the raw token itself
  tokenHash     String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Entry re-encrypted with a key imported from the raw token bytes
  encryptedBlob String
  iv            String
  /// Mirrors the entry type for display purposes (no decryption needed)
  entryType     String   @default("login")
  /// Display name shown on the share page — set by the owner at share time
  label         String
  expiresAt     DateTime
  viewCount     Int      @default(0)
  /// null = unlimited views
  maxViews      Int?
  createdAt     DateTime @default(now())

  @@index([userId])
}
