generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  /// bcrypt hash of the login password — used by next-auth for authentication only, never for encryption
  passwordHash String
  createdAt    DateTime @default(now())
  vaults       Vault[]
  tags         Tag[]
}

model Vault {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// display name chosen by the user (e.g. "Personal", "Work")
  name      String
  /// base64-encoded PBKDF2 salt; combined with this vault's password in-browser to derive the AES-256-GCM key
  salt      String
  entries   VaultEntry[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([userId, name])
}

model VaultEntry {
  id            String   @id @default(cuid())
  vaultId       String
  vault         Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  /// base64-encoded AES-256-GCM ciphertext of the vault entry JSON; server never decrypts this
  encryptedBlob String
  /// base64-encoded AES-GCM initialization vector; unique per entry, safe to store in plaintext
  iv            String
  tags          Tag[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Tag {
  id           String       @id @default(cuid())
  userId       String
  /// scoped to the owning user so tags are shared across all their vaults
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  vaultEntries VaultEntry[]
  createdAt    DateTime     @default(now())

  @@unique([userId, name])
}
