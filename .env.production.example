# Production environment — copy to .env.production and fill in real values.
# NEVER commit .env.production to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# Internal Docker network address (service name = "db")
DATABASE_URL="postgresql://postgres:CHANGEME@db:5432/cheesy_toast_vault"
POSTGRES_PASSWORD="CHANGEME"    # must match the password in DATABASE_URL

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-hex-32"
# The public URL of your deployment (no trailing slash)
NEXTAUTH_URL="https://yourdomain.com"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier covers 3 000 emails/month
RESEND_API_KEY="re_..."

# Base URL used in password-reset and email-verification links
# Should match NEXTAUTH_URL
RESET_BASE_URL="https://yourdomain.com"
