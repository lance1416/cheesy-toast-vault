# Copy to .env and fill in real values

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cheesy_toast_vault"
# Separate DB used by Playwright E2E tests — never shared with the dev DB
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/cheesy_toast_vault_test"
# Set to 1 in dev to prevent the in-memory rate limiter from exhausting across E2E runs.
# Must be absent (or unset) in production.
BYPASS_RATE_LIMIT=1

# NextAuth — generate with: openssl rand -hex 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Resend — transactional email (https://resend.com)
RESEND_API_KEY="re_..."
# "Name <address>" shown as the sender — use onboarding@resend.dev for testing
EMAIL_FROM="Cheesy Toast Vault <onboarding@resend.dev>"

# Base URL used in password-reset and verification email links
# Must match NEXTAUTH_URL in production
RESET_BASE_URL="https://yourdomain.com"
